{
  "firestore": {
    "collections": {
      "users": {
        "description": "Stores user profile data linked to Firebase Auth UID and indexed by wallet address.",
        "documents": {
          "{uid}": {
            "fields": {
              "name": {
                "type": "string",
                "description": "User-defined display name."
              },
              "walletAddress": {
                "type": "string",
                "description": "The linked blockchain wallet address (lowercase)."
              },
              "updatedAt": {
                "type": "timestamp",
                "description": "Timestamp of the last update."
              }
            }
          }
        }
      }
    }
  }
}