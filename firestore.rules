rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{address} {
      // Anyone can read a user's display name
      allow read: if true;
      // Only the authenticated user (via Anonymous Auth) can update their own entry
      // For a simple prototype, we allow the client to set this based on their wallet address
      allow write: if request.auth != null;
    }
  }
}