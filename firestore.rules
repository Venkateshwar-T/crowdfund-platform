rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to read user profiles (public display names)
    // Only allow the owner (identified by their Firebase UID) to write to their own record
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}